OPENAI_API_KEY=sk-...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_BACKEND=postgres

# Local database when running the API on your host machine.
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zakbot
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net
MONGO_DATABASE_NAME=zakbot

# Docker Compose local database settings.
DOCKER_DB_URL=postgresql+asyncpg://postgres:postgres@db:5432/zakbot
LOCAL_DB_NAME=zakbot
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=postgres
LOCAL_DB_PORT=5432

# Supabase example, if you want to switch back later:
# DB_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres?sslmode=require
EMBEDDING_MODEL=text-embedding-3-small
PORT=8000
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SEARCH_MIN_SCORE=0.45
LLM_PROVIDER=openai
OPENAI_CHAT_MODEL=gpt-4.1-mini
AI_REPLY_MAX_CONTEXT_ITEMS=6
AI_REPLY_MAX_HISTORY_MESSAGES=8
AI_REPLY_CONFIDENCE_THRESHOLD=0.7
AI_AUTO_REPLY_ENABLED_DEFAULT=true
AI_REPLY_AUDIT_LOG_ENABLED=true
AI_REPLY_AUDIT_LOG_PATH=logs/ai_reply_audit.log
AI_REPLY_AUDIT_MAX_BYTES=5242880
AI_REPLY_AUDIT_BACKUP_COUNT=5
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
PUBLIC_WEBHOOK_BASE_URL=https://api.example.com
APP_ENCRYPTION_KEY=replace-with-a-strong-secret
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_APP_BASE_URL=https://api.example.com
SHOPIFY_SCOPES=read_orders,write_orders
SHOPIFY_API_VERSION=2025-07

# Evaluation pipeline settings.
BASE_URL=http://localhost:8000
BUSINESS_ID=1
REQUEST_TIMEOUT_SECONDS=20
MAX_CONCURRENCY=5
JUDGE_MAX_CONCURRENCY=3
JUDGE_MODEL=gpt-4.1-mini
SEED_EVAL_DATA=true
CLEANUP_SEED_DATA=true
